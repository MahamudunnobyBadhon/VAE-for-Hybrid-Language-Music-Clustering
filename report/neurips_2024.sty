%% neurips_2024.sty  –  NeurIPS 2024 LaTeX Style File
%% Based on the public NeurIPS template (https://neurips.cc)
%%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/05/01 NeurIPS 2024 Style]

\@ifclassloaded{article}{}{%
  \PackageError{neurips_2024}{This style is designed for the article class}{}%
}

% --- Options ---
\newif\if@preprint     \@preprintfalse
\newif\if@final        \@finalfalse
\newif\if@nonatbib     \@nonatbibfalse

\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{\@finaltrue}
\DeclareOption{nonatbib}{\@nonatbibtrue}
\ProcessOptions\relax

% --- Page layout ---
\usepackage[
  letterpaper,
  left=1.5in, right=1.5in,
  top=1in, bottom=1in,
]{geometry}

% --- Fonts ---
\usepackage{times}
\usepackage[T1]{fontenc}
\renewcommand{\rmdefault}{ptm}
\renewcommand{\sfdefault}{phv}
\renewcommand{\ttdefault}{pcr}

% --- Spacing ---
\setlength{\parskip}{0pt}
\setlength{\parindent}{1em}
\renewcommand{\baselinestretch}{1.0}

% --- Section headings ---
\usepackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{0.5em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{0.5em}{}
\titleformat{\subsubsection}[runin]{\normalsize\bfseries}{\thesubsubsection}{0.5em}{}[.]
\titlespacing*{\section}{0pt}{10pt plus 2pt minus 2pt}{4pt}
\titlespacing*{\subsection}{0pt}{8pt plus 2pt minus 2pt}{2pt}
\titlespacing*{\subsubsection}{0pt}{6pt}{4pt}

% --- Paragraph heading (used as \paragraph{}) ---
\titleformat{\paragraph}[runin]{\normalsize\bfseries}{}{0pt}{}[.]
\titlespacing*{\paragraph}{0pt}{4pt}{0.5em}

% --- Abstract ---
\renewenvironment{abstract}{%
  \vskip 0.4in
  \begin{center}{\bf Abstract}\end{center}
  \begin{quote}\small
}{%
  \end{quote}
  \vskip 0.4in
}

% --- Title block ---
\def\@maketitle{%
  \newpage
  \null
  \vskip 2em%
  \begin{center}%
    {\LARGE \bfseries \@title \par}%
    \vskip 1.5em%
    {\large \lineskip .5em%
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}\par}%
    \vskip 1em%
    \if@preprint
      \textit{Preprint. Work in progress.}
    \fi
  \end{center}%
  \par
  \vskip 1.5em%
}

% --- Caption formatting ---
\usepackage{caption}
\captionsetup{font=small, labelfont=bf, labelsep=period}

% --- Table formatting ---
\setlength{\tabcolsep}{4pt}

% --- Footnote ---
\setlength{\footnotesep}{6pt}

% --- Natbib (optional) ---
\if@nonatbib\else
  % skip natbib – use thebibliography directly
\fi

% --- Line numbers for review ---
\if@final\else
  \if@preprint\else
    % review mode: would add line numbers here
  \fi
\fi

\endinput
